-# Строка таблицы запроса на разблокировку. Переиспользуется в index, show и
-# карточке клиента. r — экземпляр DeviceUnlockRequest (передаётся как :device_unlock_request).
- r = device_unlock_request
- status_mod = r.status.tr('_', '-')
%tr.device-unlock-requests__row{ class: "device-unlock-requests__row--#{status_mod}", id: "device_unlock_request_#{r.id}" }
  %td= human_datetime r.created_at
  %td= link_to r.client.short_name, client_path(r.client)
  %td
    = r.item.name
    - if r.item.serial_number.present?
      %br
      %small.muted= r.item.serial_number
  %td= r.reason
  %td= r.last_comment&.content
  %td.device-unlock-requests__status-cell
    %span.label{ class: "device-unlock-requests__status--#{status_mod}" }= t("device_unlock_requests.statuses.#{r.status}")
    - if policy(r).update_status?
      .device-unlock-requests__actions
        - unless r.new_request?
          = link_to t('.new_request_btn'), update_status_device_unlock_request_path(r, device_unlock_request: { status: :new_request }), method: :patch, remote: true, class: 'btn btn-info btn-small'
        - unless r.in_progress?
          = link_to t('.in_progress_btn'), update_status_device_unlock_request_path(r, device_unlock_request: { status: :in_progress }), method: :patch, remote: true, class: 'btn btn-warning btn-small'
        - unless r.needs_approval?
          = link_to t('.needs_approval_btn'), update_status_device_unlock_request_path(r, device_unlock_request: { status: :needs_approval }), method: :patch, remote: true, class: 'btn btn-small'
        - unless r.approved?
          = link_to t('.approved_btn'), update_status_device_unlock_request_path(r, device_unlock_request: { status: :approved }), method: :patch, remote: true, class: 'btn btn-success btn-small'
        - unless r.client_declined?
          = link_to t('.client_declined_btn'), update_status_device_unlock_request_path(r, device_unlock_request: { status: :client_declined }), method: :patch, remote: true, class: 'btn btn-danger btn-small'
    = history_link_to history_device_unlock_request_path(r)
