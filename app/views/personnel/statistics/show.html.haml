.page-header
  %h1= t('.title')

.well.well-small.employee-statistics__filters
  = form_tag personnel_statistics_path, method: :get, class: 'form-inline' do
    = label_tag :month, t('.month'), class: 'control-label'
    = select_tag :month,
                 options_for_select(month_options, @month.to_s),
                 class: 'input-medium',
                 onchange: 'this.form.submit()'

    = label_tag :city_id, t('.city'), class: 'control-label'
    = select_tag :city_id,
                 options_from_collection_for_select(@cities, :id, :name, @city.id),
                 class: 'input-medium',
                 onchange: 'this.form.submit()'

    = hidden_field_tag :metric, @metric

.employee-statistics
  %ul.nav.nav-tabs.employee-statistics__tabs
    - User::ACTIVITIES.each do |m|
      %li{ class: "employee-statistics__tab--#{m} #{'active' if m == @metric}" }
        = link_to t("personnel.statistics.metrics.#{m}"),
                  personnel_statistics_path(metric: m, month: @month.to_s, city_id: @city.id)

  .employee-statistics__panel{ class: "employee-statistics__panel--#{@metric}" }
    %h3= "#{t("personnel.statistics.metrics.#{@metric}")} — #{l(@month, format: '%B %Y')}, #{@city.name}"

    - if @rows.empty?
      %p.muted= t('.empty')
    - else
      %table.table.table-striped.employee-statistics__table
        %thead
          %tr
            %th{style: 'width: 60px;'}
            %th= t('.employee')
            %th{style: 'width: 120px; text-align: right;'}= t('.value')
        %tbody
          - achieved = ->(count) { @plan.target.to_i.positive? && count >= @plan.target.to_i }
          - @rows.each do |user, count|
            %tr
              %td
                - if user.photo?
                  = image_tag user.photo.thumb.url, class: 'employee-statistics__avatar'
              %td{ class: ('employee-statistics__name--achieved' if achieved.call(count)) }= user.name
              %td{style: 'text-align: right;'}= count
        %tfoot
          %tr.employee-statistics__plan-row
            %td
            %td= t('.plan_value')
            %td{style: 'text-align: right;'}
              - if can?(:update, Plan)
                - plan_data = { month: @month.to_s, 'city-id': @city.id, metric: @metric, url: personnel_plans_path }
                = number_field_tag :target, @plan.target.to_i, min: 0, class: 'employee-statistics__plan-input', data: plan_data
              - else
                = @plan.target.to_i
