// «Строгий ремонт»: ответ «Нет» обработан на сервере (маркер закрыт, processed=dismissed).
// Возвращаем размытие: технарь отказался брать устройство в работу → суть снова скрыта.
// Чтобы посмотреть снова — нужен повторный клик «глаза» (создаст новый маркер, т.к.
// этот уже dismissed). Модалку уже сняли клиентски; убираем идемпотентно.
(function() {
  var sjId = <%= @service_job.id %>;
  $('#strict_repair_modal_' + sjId).remove();
  $('.strict-repair[data-strict-repair-id="' + sjId + '"]').removeClass('strict-repair--revealed');
})();
