<% if @repair_status_error.present? %>
  alert("<%= j @repair_status_error %>");
<% else %>
  (function() {
    var html = "<%= j render('repair_status_widget', service_job: @service_job) %>";
    $('[data-repair-status-sj-id="<%= @service_job.id %>"]').each(function() {
      $(this).replaceWith(html);
    });
  })();
<% end %>
