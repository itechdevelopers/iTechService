// «Строгий ремонт» — ответ на клик «глаза» (цикл 3).
// Маркер внимания уже создан на сервере (#reveal), догонялка запланирована.
// Идемпотентно снимаем вуаль (на случай, если клиентский тоггл цикла 2 не сработал).
// Цикл 4 добавит сюда модалку «Взять в работу? Да / Нет».
(function() {
  $('.strict-repair[data-strict-repair-id="<%= @service_job.id %>"]').addClass('strict-repair--revealed');
})();
