- if @designs.blank?
  %p.muted= t('.no_stock')
- else
  -# Выбор кругляшками: одна карточка = позиция «дизайн + размер». Клик выделяет
  -# и раскрывает поле количества. «Взято» = введённое число коробок, отдельного
  -# чекбокса нет. На перерисовке после ошибки уже введённые позиции помечены
  -# --selected сервером, чтобы поле было видно с сохранённым значением.
  - entered = {}
  - @batch.withdrawals.each { |w| entered[w.package_stock_id.to_i] = w.boxes_count }

  = simple_form_for @batch, url: package_withdrawals_path,
                    as: :package_withdrawal_batch, html: { class: 'form-horizontal' } do |f|
    -# Базовые ошибки контейнера (не выбрано ни одной позиции, есть ошибочные
    -# строки). Ошибки самих полей (дата/основание) simple_form покажет инлайн.
    - if @batch.errors[:base].any?
      .alert.alert-error
        %ul
          - @batch.errors[:base].uniq.each do |msg|
            %li= msg

    - @batch.withdrawals.select { |w| w.errors.any? }.each do |w|
      %p.text-error
        = "#{w.package_stock&.package_design&.name} · #{w.package_stock&.size}: #{w.errors.full_messages.to_sentence}"

    %p.muted= t('.picker_hint')

    #package_withdrawal_picker.package-withdrawal-picker
      - @designs.each do |design|
        - design.package_stocks.each do |stock|
          - out_of_stock = stock.boxes_count.to_i.zero?
          - taken = entered[stock.id].to_i
          - selected = taken.positive?
          %div.package-withdrawal-picker__item{ class: [('package-withdrawal-picker__item--selected' if selected), ('package-withdrawal-picker__item--disabled' if out_of_stock)].compact }
            - if design.image?
              = image_tag design.image.thumb.url, class: 'package-withdrawal-picker__thumb', alt: design.name
            - else
              %span.package-withdrawal-picker__thumb--placeholder= design.name.first
            %span.package-withdrawal-picker__design= design.name
            %span.package-withdrawal-picker__size= stock.size
            %span.package-withdrawal-picker__avail
              = out_of_stock ? t('.out_of_stock') : t('.available', count: stock.boxes_count)
            - unless out_of_stock
              = hidden_field_tag 'package_withdrawal_batch[lines][][package_stock_id]', stock.id
              = number_field_tag 'package_withdrawal_batch[lines][][boxes_count]', (taken if selected),
                                 min: 1, max: stock.boxes_count,
                                 class: 'package-withdrawal-picker__qty', 'aria-label' => t('.qty_label')

    = f.input :withdrawn_on, as: :string,
              input_html: { type: 'date', value: (@batch.withdrawn_on || Date.current) }
    = f.input :reason, label: t('.reason_label'), hint: t('.reason_hint')

    .form-actions
      = submit_button f

  :javascript
    (function () {
      var picker = document.getElementById('package_withdrawal_picker');
      if (!picker) return;
      var SEL = 'package-withdrawal-picker__item--selected';
      var items = picker.querySelectorAll('.package-withdrawal-picker__item:not(.package-withdrawal-picker__item--disabled)');

      Array.prototype.forEach.call(items, function (item) {
        var qty = item.querySelector('.package-withdrawal-picker__qty');
        if (!qty) return;

        function select(on) {
          if (on) {
            item.classList.add(SEL);
            if (!qty.value || parseInt(qty.value, 10) < 1) qty.value = 1;
          } else {
            item.classList.remove(SEL);
            qty.value = '';
          }
        }

        item.addEventListener('click', function (e) {
          if (e.target === qty) return; // клик по самому полю не переключает выбор
          select(!item.classList.contains(SEL));
        });
        qty.addEventListener('click', function (e) { e.stopPropagation(); });
        qty.addEventListener('input', function () {
          item.classList.toggle(SEL, parseInt(qty.value, 10) >= 1);
        });
      });
    })();
