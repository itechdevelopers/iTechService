#dashboard_repair_status_summary
  - if @repair_status_summary.present?
    .repair-status-summary
      .repair-status-summary__header
        %span.repair-status-summary__title= t('dashboard.repair_status_summary.title', default: 'Сводка по ремонту')
        %span.repair-status-summary__scope= @repair_status_summary[:location_name]
      .repair-status-summary__tiles
        .repair-status-summary__tile.repair-status-summary__tile--total
          .repair-status-summary__count= @repair_status_summary[:total]
          .repair-status-summary__label= t('dashboard.repair_status_summary.total', default: 'Всего на ремонте')
        - @repair_status_summary[:statuses].each do |status|
          .repair-status-summary__tile{ class: "repair-status-summary__tile--#{status[:code]}", style: ("border-top-color: #{status[:color]};" if status[:color].present?), data: { status_code: status[:code] } }
            .repair-status-summary__count{ style: ("color: #{status[:color]};" if status[:color].present?) }= status[:count]
            .repair-status-summary__label= status[:name]
