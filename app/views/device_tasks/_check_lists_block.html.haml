- check_lists = defined?(available_check_lists) ? available_check_lists : @device_task.available_check_lists
- if check_lists.any?
  %h4= t('check_lists.title', default: 'Check Lists')
  .well.well-small
    - check_lists.each_with_index do |check_list, index|
      - response = check_list_response_for(@device_task, check_list) || @device_task.check_list_responses.build(check_list: check_list)
      .check-list-container.control-group
        %label.control-label= check_list.name
        .controls
          = hidden_field_tag "device_task[check_list_responses_attributes][#{index}][check_list_id]", check_list.id
          - if response.persisted?
            = hidden_field_tag "device_task[check_list_responses_attributes][#{index}][id]", response.id

          - if check_list.has_main_question?
            - main_item = check_list.main_question
            - current_answer = response.answer_for_item(main_item.id)
            = render 'check_lists/check_list_item_response', model_name: 'device_task', index: index, item: main_item, response: response, is_main: true, indent: false

            - show_sub = main_item.custom_answers? ? current_answer.present? : current_answer == 'yes'
            .subordinate-questions{style: show_sub ? '' : 'display: none;'}
              - check_list.subordinate_items.each do |item|
                = render 'check_lists/check_list_item_response', model_name: 'device_task', index: index, item: item, response: response, is_main: false, indent: true
          - else
            - check_list_items_for(check_list).each do |item|
              = render 'check_lists/check_list_item_response', model_name: 'device_task', index: index, item: item, response: response, is_main: false, indent: false
