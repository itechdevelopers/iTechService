- archived_view = local_assigns[:archived_view]

.page-header
  %h1
    = archived_view ? t('products.archived.title') : auto_title
    %small
      - if archived_view
        = link_to 'Вернуться к активным продуктам', products_path
      - else
        = link_to 'Архив', archived_products_path, class: 'text-muted'

.row-fluid
  .span4
    - if can?(:manage, Product) && !archived_view
      = link_to "#{glyph(:file)} #{t('.new_product_group')}".html_safe, new_product_group_path, remote: true, class: 'btn btn-success', id: 'new_product_group_link'
      = link_to "#{glyph(:file)} #{t('.new_product')}".html_safe,
                @current_product_group.present? ? new_product_path(product: {product_group_id: @current_product_group.id}) : '#',
                class: 'btn btn-success', id: 'new_product_link', disabled: !@current_product_group.present?

  .span8
    .table_filter.navbar
      .navbar-inner
        = form_tag (archived_view ? archived_products_path : products_path), method: 'get', id: 'search_form', class: 'navbar-search form-search', remote: true do
          = hidden_field_tag :group, params[:group] if params[:group].present?
          .input-append
            = text_field_tag :query, params[:query], id: 'product_search_field', class: 'search-query input-medium', placeholder: ''
            %span.add-on.btn.clear_search_input
              %i.icon-remove

.row-fluid
  .span4
    #product_groups= product_groups_trees_tag @product_groups, @opened_product_groups, params[:group], (archived_view ? { archived_view: true } : {})

  #resource_table.span8= render(params[:table_name] || 'table')
