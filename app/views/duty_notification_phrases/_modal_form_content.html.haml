.modal-header
  = button_to_close_modal
  %h3= t('.title')

.modal-body
  = form_with model: @phrase, url: duty_notification_phrases_path, local: false, class: 'form-inline', id: 'phrase_form' do |f|
    = f.text_field :text, class: 'input-xlarge', placeholder: t('.text_placeholder')
    = f.submit t('.add'), class: 'btn btn-success'

  %hr

  #phrases_list
    = render 'list'

.modal-footer
  = link_to t('helpers.links.close'), '#', 'data-dismiss' => 'modal', class: 'btn'
