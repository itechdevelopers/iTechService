.page-header
  %h1
    = link_back_to_index
    = t 'users.duty_schedule'

%ul.nav.nav-tabs
  %li.active
    %a{href: '#tab_old_duty', 'data-toggle' => 'tab'}= t('users.schedule_tabs.old_duty')
  %li
    %a{href: '#tab_new_duty', 'data-toggle' => 'tab'}= t('users.schedule_tabs.new_duty')
  %li
    %a{href: '#tab_cashier', 'data-toggle' => 'tab'}= t('users.schedule_tabs.cashier')
  %li
    %a{href: '#tab_store_closing', 'data-toggle' => 'tab'}= t('users.schedule_tabs.store_closing')

.tab-content
  #tab_old_duty.tab-pane.active
    .row-fluid
      .span12
        - DutyDay::KINDS.each do |kind|
          = duty_calendar(kind, Date.current.beginning_of_month)

  #tab_new_duty.tab-pane
    %h3= t('users.schedule_tabs.department_select')
    .btn-group
      - @departments.each do |department|
        = link_to department.name, '#', class: 'btn btn-department-select', data: { department_id: department.id }
    - if can?(:manage, :schedule)
      .pull-right
        = link_to duty_schedule_color_settings_path, remote: true, class: 'btn btn-small' do
          = glyph(:tint)
          = t('users.schedule_tabs.cell_colors')
        = link_to duty_notification_phrases_path, remote: true, class: 'btn btn-small' do
          = glyph(:comment)
          = t('users.schedule_tabs.manage_phrases')
    #new_duty_schedule_content
      %p.muted= t('users.schedule_tabs.select_department_hint')

  #tab_cashier.tab-pane
    %h3= t('users.schedule_tabs.department_select')
    .btn-group
      - @departments.each do |department|
        = link_to department.name, '#', class: 'btn btn-cashier-department-select', data: { department_id: department.id }
    - if can?(:manage, :schedule)
      .pull-right
        = link_to duty_schedule_color_settings_path, remote: true, class: 'btn btn-small' do
          = glyph(:tint)
          = t('users.schedule_tabs.cell_colors')
        = link_to cashier_notification_phrases_path, remote: true, class: 'btn btn-small' do
          = glyph(:comment)
          = t('users.schedule_tabs.manage_cashier_phrases')
    #cashier_schedule_content
      %p.muted= t('users.schedule_tabs.select_department_hint_cashier')

  #tab_store_closing.tab-pane
    %h3= t('users.schedule_tabs.department_select')
    .btn-group
      - @departments.each do |department|
        = link_to department.name, '#', class: 'btn btn-store-closing-department-select', data: { department_id: department.id }
    - if can?(:manage, :schedule)
      .pull-right
        = link_to duty_schedule_color_settings_path, remote: true, class: 'btn btn-small' do
          = glyph(:tint)
          = t('users.schedule_tabs.cell_colors')
        = link_to store_closing_notification_phrases_path, remote: true, class: 'btn btn-small' do
          = glyph(:comment)
          = t('users.schedule_tabs.manage_store_closing_phrases')
    #store_closing_schedule_content
      %p.muted= t('users.schedule_tabs.select_department_hint_store_closing')

:javascript
  $(function() {
    // === Duty Schedule (tab_new_duty) ===
    var dutyDepartmentId = null;
    var dutyMode = null;

    $('#tab_new_duty').on('click', '.btn-department-select', function(e) {
      e.preventDefault();
      dutyDepartmentId = $(this).data('department-id');
      dutyMode = null;
      $.ajax({
        url: '#{duty_schedule_path}',
        data: { department_id: dutyDepartmentId },
        dataType: 'script'
      });
    });

    $('#new_duty_schedule_content').on('click', '.duty-schedule__tool-btn', function() {
      var $btn = $(this);
      var mode = $btn.data('mode');
      if (dutyMode === mode) {
        dutyMode = null;
        $btn.removeClass('active');
      } else {
        dutyMode = mode;
        $('.duty-schedule__tool-btn').removeClass('active');
        $btn.addClass('active');
      }
    });

    $('#new_duty_schedule_content').on('click', '.duty-schedule__cell', function() {
      if (!dutyDepartmentId || !dutyMode) return;
      var $cell = $(this);
      var userId = $cell.data('user-id');
      var date = $cell.data('date');
      if (dutyMode === 'assign') {
        $.ajax({
          url: '#{assign_duty_schedule_path}',
          method: 'POST',
          data: { department_id: dutyDepartmentId, user_id: userId, date: date },
          dataType: 'script'
        });
      } else if (dutyMode === 'clear') {
        $.ajax({
          url: '#{unassign_duty_schedule_path}',
          method: 'DELETE',
          data: { department_id: dutyDepartmentId, user_id: userId, date: date },
          dataType: 'script'
        });
      }
    });

    // === Cashier Schedule (tab_cashier) ===
    var cashierDepartmentId = null;
    var cashierMode = null;

    $('#tab_cashier').on('click', '.btn-cashier-department-select', function(e) {
      e.preventDefault();
      cashierDepartmentId = $(this).data('department-id');
      cashierMode = null;
      $.ajax({
        url: '#{cashier_schedule_path}',
        data: { department_id: cashierDepartmentId },
        dataType: 'script'
      });
    });

    $('#cashier_schedule_content').on('click', '.cashier-schedule__tool-btn', function() {
      var $btn = $(this);
      var mode = $btn.data('mode');
      if (cashierMode === mode) {
        cashierMode = null;
        $btn.removeClass('active');
      } else {
        cashierMode = mode;
        $('.cashier-schedule__tool-btn').removeClass('active');
        $btn.addClass('active');
      }
    });

    $('#cashier_schedule_content').on('click', '.cashier-schedule__cell', function() {
      if (!cashierDepartmentId || !cashierMode) return;
      var $cell = $(this);
      var userId = $cell.data('user-id');
      var date = $cell.data('date');
      if (cashierMode === 'assign') {
        $.ajax({
          url: '#{assign_cashier_schedule_path}',
          method: 'POST',
          data: { department_id: cashierDepartmentId, user_id: userId, date: date },
          dataType: 'script'
        });
      } else if (cashierMode === 'clear') {
        $.ajax({
          url: '#{unassign_cashier_schedule_path}',
          method: 'DELETE',
          data: { department_id: cashierDepartmentId, user_id: userId, date: date },
          dataType: 'script'
        });
      }
    });

    // === Store Closing Schedule (tab_store_closing) ===
    var storeClosingDepartmentId = null;
    var storeClosingMode = null;

    $('#tab_store_closing').on('click', '.btn-store-closing-department-select', function(e) {
      e.preventDefault();
      storeClosingDepartmentId = $(this).data('department-id');
      storeClosingMode = null;
      $.ajax({
        url: '#{store_closing_schedule_path}',
        data: { department_id: storeClosingDepartmentId },
        dataType: 'script'
      });
    });

    $('#store_closing_schedule_content').on('click', '.store-closing-schedule__tool-btn', function() {
      var $btn = $(this);
      var mode = $btn.data('mode');
      if (storeClosingMode === mode) {
        storeClosingMode = null;
        $btn.removeClass('active');
      } else {
        storeClosingMode = mode;
        $('.store-closing-schedule__tool-btn').removeClass('active');
        $btn.addClass('active');
      }
    });

    $('#store_closing_schedule_content').on('click', '.store-closing-schedule__cell', function() {
      if (!storeClosingDepartmentId || !storeClosingMode) return;
      var $cell = $(this);
      var userId = $cell.data('user-id');
      var date = $cell.data('date');
      if (storeClosingMode === 'assign') {
        $.ajax({
          url: '#{assign_store_closing_schedule_path}',
          method: 'POST',
          data: { department_id: storeClosingDepartmentId, user_id: userId, date: date },
          dataType: 'script'
        });
      } else if (storeClosingMode === 'clear') {
        $.ajax({
          url: '#{unassign_store_closing_schedule_path}',
          method: 'DELETE',
          data: { department_id: storeClosingDepartmentId, user_id: userId, date: date },
          dataType: 'script'
        });
      }
    });
  });
