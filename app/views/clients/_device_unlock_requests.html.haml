-# Секция «Запросы на разблокировку» в карточке клиента. Переиспользует
-# строку-партиал device_unlock_requests/_device_unlock_request (та же
-# разметка, что в общей таблице). includes(:comments) — против N+1 в last_comment.
- requests = client.device_unlock_requests.recent.includes(:item, :comments)
- if requests.any?
  #device_unlock_requests_section
    %table.table.table-bordered.table-condensed.table-hover.device-unlock-requests
      %caption
        %h4= t('device_unlock_requests.client_section.title')
      %thead
        %tr
          %th= t('device_unlock_requests.index.columns.created_at')
          %th= DeviceUnlockRequest.human_attribute_name(:client)
          %th= DeviceUnlockRequest.human_attribute_name(:item)
          %th= DeviceUnlockRequest.human_attribute_name(:reason)
          %th= t('device_unlock_requests.index.columns.last_comment')
          %th= DeviceUnlockRequest.human_attribute_name(:status)
      %tbody
        = render partial: 'device_unlock_requests/device_unlock_request', collection: requests, as: :device_unlock_request
